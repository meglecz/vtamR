# vecteurs de départ:
prenoms <- c("Pierre", "Anna", "Youssef", "Yuki", "Anastasia", "Dmitri", "Zara", "Liam")
ages <- c(2, 78, 26, 17, 8, NA, 18, 43)
# 1. Vérifiez le nombre d’éléments dans chaque vecteur à l’aide des commandes R. Si les deux vecteurs ont le même nombre d’éléments, associez les prénoms comme noms des éléments du vecteur ages
length(prenoms)
length(ages)
?names
if (length(prenoms) == length(ages)) {
names(ages) <- prenoms
}
# 2. Calculez les statistiques de base sur les âges : Trouvez l’âge moyen, minimum et maximum parmi ces personnes, et stockez chacune de ces valeurs dans une variable distincte.
age_moyen <- mean(ages, na.rm = TRUE)
age_min <- min(ages, na.rm = TRUE)
age_max <- max(ages, na.rm = TRUE)
age_moyen
age_min
age_max
# 3. Créez un vecteur pour les personnes majeures : Conservez uniquement les personnes âgées de 18 ans ou plus et excluez celles dont l’âge est inconnu (piste : `?is.na`).
personnes_majeures <- ages[ages >= 18 & !is.na(ages)]
personnes_majeures
# 4. Comptez les personnes majeures : Affichez combien de personnes sont majeures.
nb_majeurs <- length(personnes_majeures)
nb_majeurs
# 5. Identifiez les personnes plus jeunes que la moyenne : Affichez les personnes dont l’âge est inférieur à l’âge moyen du groupe, en excluant celles avec un âge inconnu.
plus_jeunes_que_moyenne <- names(ages[ages < age_moyen & !is.na(ages)])
plus_jeunes_que_moyenne
# 6. Trouvez la personne la plus âgée : Affichez le nom de la personne la plus âgée (pas son âge).
personne_plus_agee <- names(ages[ages == age_max])
personne_plus_agee <- names(ages[ages == age_max && !is.na(ages)])
personne_plus_agee <- names(ages[ages == age_max & !is.na(ages)])
personne_plus_agee
