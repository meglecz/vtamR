taxa_df_tl <- taxa_df_tl %>%
mutate(
classification = case_when(
# --- Case 1: only one unique taxon
n_unique_taxa == 1 ~ {
taxon <- unique_taxa[[1]]
n = sum(taxa_simple == taxon, na.rm=TRUE) # number of clusters where
# the taxon is present
if(n == 1) "closed" else "open"
},
TRUE ~ "hybrid"
)
)
